basename-about =
    Exibe o NOME com qualquer componente de diretório principal removido
    se especificado, também remover um SUFIXO final
basename-usage =
    basename [-z] NOME [SUFIXO]
    basename OPÇÃO... NOME...
basename-error-missing-operand = operando ausente
basename-error-extra-operand = operando extra { $operand }
basename-help-multiple = suporta múltiplos argumentos e trata cada como um NOME
basename-help-suffix = remove um SUFIXO final; implica -a
basename-help-zero = termina cada linha de saída com um caractere NUL, e não com um caractere de nova linha
