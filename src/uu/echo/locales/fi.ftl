echo-about = Näytä tekstirivi
echo-usage = echo [VALITSIMET]... [JONO]...
echo-after-help =
    Kaiuta JONOT vakiotulosteeseen.

    Jos -e annetaan, tunnistetaan seuraavat jaksot:

    - \ kenoviiva
    - \a huomio (BEL)
    - \b askelpalautin
    - \c älä tulosta enempää
    - \e Esc
    - \f lomakkeensyöttö
    - \n rivinvaihto
    - \r vaununpalautin
    - \t vaakasarkain
    - \v pystysarkain
    - \0NNN oktaaliarvon NNN tavu (1 - 3 numeroa)
    - \xHH heksadesimaaliarvon HH tavu (1 - 2 numeroa)
echo-help-no-newline = älä tulosta lopun rivinvaihtoa
echo-help-enable-escapes = tulkitse kenoviivajaksot
echo-help-disable-escapes = älä tulkitse kenoviivajaksoja (oletus)
echo-error-non-utf8 = Annettu ei-UTF-8-argumentteja, mutta alusta ei tue niitä
