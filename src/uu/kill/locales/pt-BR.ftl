kill-about = Envia um sinal aos processos ou listar informações sobre sinais.
kill-usage = kill [OPÇÕES]... PID...
kill-help-list = Lista os sinais
kill-help-table = Lista uma tabela de sinais
kill-help-signal = Envia o sinal especificado em vez de SIGTERM
kill-error-no-process-id =
    nenhum ID de processo especificado
