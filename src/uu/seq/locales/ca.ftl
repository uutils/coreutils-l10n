seq-about = Mostra nombres de PRIMER a DARRER, en intervals d'INCREMENT.
seq-usage =
    seq [OPCIONS]... DARRER
    seq [OPCIONS]... PRIMER DARRER
    seq [OPCIONS]... PRIMER INCREMENT DARRER
seq-help-separator = Caràcter de separació (\n per defecte)
seq-help-terminator = Caràcter de finalització (\n per defecte)
seq-help-equal-width = Igualar l'amplada de tots els nombres mitjançant zeros a l'esquerra
seq-help-format = emprar un FORMAT de printf per nombres de punt flotant
seq-error-parse = invàlid { $type } argument: { $arg }
seq-error-zero-increment = un valor d'increment nul és invàlid: { $arg }
seq-error-no-arguments = hi manca un operand
seq-error-format-and-equal-width = no cal especificar un format quan es mostren nombres d'amplades iguals
seq-parse-error-type-float = punt flotant
seq-parse-error-type-nan = no és un nombre
