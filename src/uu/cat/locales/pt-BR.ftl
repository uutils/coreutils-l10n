cat-about =
    Concatenar ARQUIVO(s), ou entrada padrão, para saída padrão
    Sem um ARQUIVO, ou quando ARQUIVO for -, lê a entrada padrão.
cat-usage = cat [OPÇÃO]... [ARQUIVO]...
cat-help-number-nonblank = indica o número de linhas de saída não vazias, substitui a opção -n
cat-help-show-nonprinting-ends = equivalente a -vE
cat-help-show-all = equivalente a -vET
cat-help-show-ends = exibe $ no final de cada linha
cat-help-number = numera todas as linhas de saída
cat-help-squeeze-blank = suprime linhas de saída vazias repetidas
cat-help-show-nonprinting-tabs = equivalente a -vT
cat-help-ignored-u = (ignorado)
cat-error-unknown-filetype = tipo de arquivo desconhecido: { $ft_debug }
cat-error-is-directory = É um diretório
cat-error-input-file-is-output-file = arquivo de entrada é arquivo de saída
cat-error-too-many-symbolic-links = Demasiados níveis de links simbólicos
cat-error-no-such-device-or-address = Não existe tal dispositivo ou endereço
cat-help-show-tabs = exibe caracteres de tabulação como ^I
