rmdir-about = Exclui o(s) DIRETÓRIO(s), caso estejam vazio(s).
rmdir-usage = rmdir [OPÇÃO]... DIRETÓRIO...
rmdir-help-ignore-fail-non-empty = ignora cada falha que se deva exclusivamente ao fato de um diretório não estar vazio
rmdir-help-parents = remove o DIRETÓRIO e seus diretórios superiores; p. ex., 'rmdir -p a/b/c' é equivalente a rmdir a/b/c a/b a
rmdir-help-verbose = exibe um diagnóstico para cada diretório processado
rmdir-error-symbolic-link-not-followed = falha ao remover { $path }: Link simbólico não seguido
rmdir-error-failed-to-remove = falha ao remover { $path }: { $err }
rmdir-verbose-removing-directory = { $util_name }: removendo diretório, { $path }
